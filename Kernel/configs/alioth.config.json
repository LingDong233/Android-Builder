[
  {
    "kernelSource": {
      "name": "alioth",
      "repo": "https://github.com/LineageOS/android_kernel_xiaomi_sm8250",
      "branch": "lineage-21",
      "device": "alioth",
      "defconfig": "vendor/xiaomi/alioth.config"
    },
    "toolchains": [
      {
        "repo": "https://android.googlesource.com/platform/prebuilts/clang/host/linux-x86",
        "branch": "clang-r530567",
        "name": "clang",
        "binaryEnv": ["./bin"]
      },
      {
        "repo": "https://android.googlesource.com/platform/prebuilts/gcc/linux-x86/aarch64/aarch64-linux-android-4.9",
        "branch": "android-14.0.0_r0.140",
        "name": "aarch64",
        "binaryEnv": ["./bin"]
      }
    ],
    "enableCcache": true,
    "params": {
      "ARCH": "arm64",
      "CC": "clang",
      "externalCommands": {
        "CLANG_TRIPLE": "aarch64-linux-gnu-",
        "CROSS_COMPILE": "aarch64-linux-android-"
      }
    },
    "AnyKernel3": {
      "use": true,
      "release": true
    },
    "enableKernelSU": false,
    "enableLXC": true
  }
  ]
